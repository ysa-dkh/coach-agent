# ---- Copie ce fichier en .env et remplis les valeurs ----

# Port local (Scalingo l'injecte automatiquement en prod)
PORT=3000

# Redis : en local lance `docker run -p 6379:6379 redis` puis :
#   SCALINGO_REDIS_URL=redis://localhost:6379
# En prod, l'addon Redis Scalingo injecte SCALINGO_REDIS_URL tout seul.
SCALINGO_REDIS_URL=redis://localhost:6379

# Supabase (Project Settings > API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # cle "service_role" (cote serveur, bypass RLS)

# Gemini (https://aistudio.google.com/app/apikey - gratuit)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# En local on lance le worker DANS le process web (un seul `npm start` suffit).
# En prod Scalingo : mets 0 et scale un dyno worker (cf Procfile).
INLINE_WORKER=1

# Seuil de confiance : sous ce seuil, l'agent NE diagnostique pas, il redirige vers le cours.
CONFIANCE_MIN=0.6
